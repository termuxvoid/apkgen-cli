#!/data/data/com.termux/files/usr/bin/bash

# ------------------------------
# CONFIGURATION
# ------------------------------
TEMPLATE_BASE="$PREFIX/share/apkgen/templates"
DEFAULT_APP_NAME="apkgentemplate"
DEFAULT_PACKAGE="com.apkgen.template"
VERSION="1.3.0"

# ------------------------------
# COLORS
# ------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ------------------------------
# HELPERS
# ------------------------------
error() {
    echo -e "${RED}${BOLD}Error:${RESET} ${RED}$1${RESET}" >&2
    exit 1
}

success() {
    echo -e "${GREEN}${BOLD}✓${RESET} $1"
}

step() {
    echo -e "${CYAN}${BOLD}=>${RESET} $1"
}

spinner() {
    local msg="$1"
    shift
    gum spin --spinner dot --title "$msg" -- "$@"
}

escape_dots() { echo "$1" | sed 's/\./\\./g'; }

# Convert package name (com.example.app) to JNI-style (com_example_app)
pkg_to_jni() {
    echo "$1" | tr '.' '_'
}

# ------------------------------
# TEMPLATE COPY & RENAME
# ------------------------------
update_text_files() {
    local dir="$1" old="$2" new="$3"
    local old_esc=$(escape_dots "$old")
    local new_esc=$(escape_dots "$new")
    find "$dir" -type f -not -path '*/\.git/*' -exec grep -Il '.' {} \; | while read -r f; do
        sed -i "s/$old_esc/$new_esc/g" "$f"
    done
}

restructure_dirs() {
    local dir="$1" old="$2" new="$3"
    local old_path="${old//.//}" new_path="${new//.//}"

    for src_root in "app/src/main/java" "app/src/main/kotlin" \
                     "app/src/androidTest/java" "app/src/androidTest/kotlin" \
                     "app/src/test/java" "app/src/test/kotlin"; do
        local root_dir="$dir/$src_root"
        [ -d "$root_dir" ] || continue

        local old_dir="$root_dir/$old_path"
        local new_dir="$root_dir/$new_path"

        if [ -z "$old_path" ]; then
            find "$root_dir" -maxdepth 1 -type f \( -name "*.java" -o -name "*.kt" \) | while read -r src_file; do
                mkdir -p "$new_dir"
                mv "$src_file" "$new_dir/"
            done
        else
            if [ -d "$old_dir" ]; then
                mkdir -p "$new_dir"
                find "$old_dir" -type f \( -name "*.java" -o -name "*.kt" \) | while read -r src_file; do
                    local rel_path="${src_file#$old_dir/}"
                    local target="$new_dir/$rel_path"
                    mkdir -p "$(dirname "$target")"
                    mv "$src_file" "$target"
                done
                rm -rf "$old_dir"
                local p="$(dirname "$old_dir")"
                while [ "$p" != "$root_dir" ] && [ -d "$p" ] && [ -z "$(ls -A "$p" 2>/dev/null)" ]; do
                    rmdir "$p" 2>/dev/null
                    p="$(dirname "$p")"
                done
            fi
        fi
    done
}

# Native C++ specific: update JNI function name in native-lib.cpp
update_native_cpp() {
    local cpp_file="$1/app/src/main/cpp/native-lib.cpp"
    [ -f "$cpp_file" ] || return
    local old_pkg="$2"
    local new_pkg="$3"
    local old_jni="Java_$(pkg_to_jni "$old_pkg")_MainActivity_stringFromJNI"
    local new_jni="Java_$(pkg_to_jni "$new_pkg")_MainActivity_stringFromJNI"
    sed -i "s/$old_jni/$new_jni/g" "$cpp_file"
}

# Flutter‑specific updates
update_flutter_app_name() {
    local manifest="$1/android/app/src/main/AndroidManifest.xml"
    [ -f "$manifest" ] || return
    sed -i "s/android:label=\".*\"/android:label=\"$2\"/" "$manifest"
}

update_flutter_build_gradle() {
    local build_gradle="$1/android/app/build.gradle.kts"
    [ -f "$build_gradle" ] || return
    local old_esc=$(escape_dots "$2")
    local new_esc=$(escape_dots "$3")
    sed -i "s/namespace = \"$old_esc\"/namespace = \"$new_esc\"/" "$build_gradle"
    sed -i "s/applicationId = \"$old_esc\"/applicationId = \"$new_esc\"/" "$build_gradle"
}

update_flutter_manifest() {
    local manifest="$1/android/app/src/main/AndroidManifest.xml"
    [ -f "$manifest" ] || return
    local old_esc=$(escape_dots "$2")
    local new_esc=$(escape_dots "$3")
    sed -i "s/package=\"$old_esc\"/package=\"$new_esc\"/" "$manifest"
}

# Native Android functions
update_build_gradle() {
    local f="$1/app/build.gradle"
    [ -f "$f" ] || return
    local old_esc=$(escape_dots "$2")
    local new_esc=$(escape_dots "$3")
    sed -i "s/applicationId \"$old_esc\"/applicationId \"$new_esc\"/" "$f"
    sed -i "s/namespace \"$old_esc\"/namespace \"$new_esc\"/" "$f"
}

update_manifest() {
    local f="$1/app/src/main/AndroidManifest.xml"
    [ -f "$f" ] || return
    local old_esc=$(escape_dots "$2")
    local new_esc=$(escape_dots "$3")
    sed -i "s/package=\"$old_esc\"/package=\"$new_esc\"/" "$f"
}

update_app_name() {
    local f="$1/app/src/main/res/values/strings.xml"
    [ -f "$f" ] && sed -i "s/$2/$3/g" "$f"
}

# ------------------------------
# BANNER
# ------------------------------
show_banner() {
    clear
    gum style \
        --foreground 63 --border double --border-foreground 63 \
        --padding "1 2" --margin "1 2" \
        "APKGen v${VERSION}" \
        "Android APK Generator CLI"
}

# ------------------------------
# CREATE COMMAND
# ------------------------------
create_app() {
    local app_dir=""
    local use_kotlin=false
    local use_flutter=false
    local use_nativecpp=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --kotlin) use_kotlin=true; shift ;;
            --flutter) use_flutter=true; shift ;;
            --nativecpp) use_nativecpp=true; shift ;;
            *)
                if [ -z "$app_dir" ]; then
                    app_dir="$1"
                    shift
                else
                    error "Unknown argument: $1"
                fi
                ;;
        esac
    done

    [ -z "$app_dir" ] && error "Usage: apkgen create <app-directory> [--kotlin|--flutter|--nativecpp]"

    local type_count=0
    [ "$use_kotlin" = true ] && ((type_count++))
    [ "$use_flutter" = true ] && ((type_count++))
    [ "$use_nativecpp" = true ] && ((type_count++))
    if [ $type_count -gt 1 ]; then
        error "Cannot use multiple --flags. Choose exactly one of --kotlin, --flutter, or --nativecpp."
    fi

    if [ -e "$app_dir" ]; then
        error "A project with this name already exists"
    fi

    local template_type="java"
    if [ "$use_kotlin" = true ]; then
        template_type="kotlin"
    elif [ "$use_flutter" = true ]; then
        template_type="flutter"
    elif [ "$use_nativecpp" = true ]; then
        template_type="nativecpp"
    fi

    local template_dir="$TEMPLATE_BASE/$template_type"
    if [ ! -d "$template_dir" ]; then
        error "Template directory not found: $template_dir"
    fi

    echo
    spinner "Copying $template_type template..." cp -r "$template_dir" "$app_dir"
    if [ $? -ne 0 ]; then
        error "Copy failed"
    fi

    # .git is deliberately NOT removed – it stays as is from the template

    cd "$app_dir" || error "Cannot enter $app_dir"

    echo
    echo -e "${BOLD}Configuration${RESET}"
    echo -e "${DIM}Please provide the following information:${RESET}"
    echo

    echo -e "${CYAN}App name${RESET} (e.g., MyApp)"
    new_name=$(gum input \
        --placeholder "MyApp" \
        --prompt "> " \
        --prompt.foreground 39 \
        --placeholder.foreground 241 \
        --value "$DEFAULT_APP_NAME" \
        --width 60)

    echo
    echo -e "${CYAN}Package name${RESET} (e.g., com.example.myapp)"
    new_pkg=$(gum input \
        --placeholder "com.example.myapp" \
        --prompt "> " \
        --prompt.foreground 39 \
        --placeholder.foreground 241 \
        --value "$DEFAULT_PACKAGE" \
        --width 60)

    echo
    step "Restructuring project..."

    if [ "$use_flutter" = true ]; then
        update_flutter_app_name "$(pwd)" "$new_name"
        update_flutter_manifest "$(pwd)" "$DEFAULT_PACKAGE" "$new_pkg"
        update_flutter_build_gradle "$(pwd)" "$DEFAULT_PACKAGE" "$new_pkg"
        update_text_files "$(pwd)/android" "$DEFAULT_PACKAGE" "$new_pkg"
        restructure_dirs "$(pwd)/android" "$DEFAULT_PACKAGE" "$new_pkg"
    else
        # Native Android (java, kotlin, nativecpp)
        update_app_name "$(pwd)" "$DEFAULT_APP_NAME" "$new_name"
        update_manifest "$(pwd)" "$DEFAULT_PACKAGE" "$new_pkg"
        update_build_gradle "$(pwd)" "$DEFAULT_PACKAGE" "$new_pkg"
        update_text_files "$(pwd)" "$DEFAULT_PACKAGE" "$new_pkg"
        restructure_dirs "$(pwd)" "$DEFAULT_PACKAGE" "$new_pkg"

        # Extra step for nativecpp: update JNI function name
        if [ "$use_nativecpp" = true ]; then
            update_native_cpp "$(pwd)" "$DEFAULT_PACKAGE" "$new_pkg"
        fi
    fi

    echo
    success "Project created successfully"
    echo
    echo -e "${BOLD}Next steps:${RESET}"
    echo -e "  ${DIM}1.${RESET} ${WHITE}cd $app_dir${RESET}"
    if [ "$use_flutter" = true ]; then
        echo -e "  ${DIM}2.${RESET} ${WHITE}apkgen build flutter${RESET}"
    else
        echo -e "  ${DIM}2.${RESET} ${WHITE}apkgen build debug${RESET}"
    fi
    echo
}

# ------------------------------
# BUILD COMMANDS
# ------------------------------
ensure_gradlew() {
    if [ -f "gradlew" ] && [ ! -x "gradlew" ]; then
        chmod +x gradlew
    elif [ ! -f "gradlew" ]; then
        error "gradlew not found. Are you in a valid Android project?"
    fi
}

build_apk() {
    local build_type="$1"
    ensure_gradlew

    if [ "$build_type" = "debug" ]; then
        step "Building debug APK..."
        ./gradlew assembleDebug --no-daemon
        if [ $? -ne 0 ]; then
            error "Build failed"
        fi
        local apk=$(find app/build/outputs/apk -name "*debug*.apk" | head -1)
        [ -z "$apk" ] && error "APK not found"
        success "Build completed"
        echo -e "  ${DIM}Output:${RESET} ${GREEN}$(realpath "$apk")${RESET}"
    elif [ "$build_type" = "release" ]; then
        step "Building release APK (unsigned)..."
        ./gradlew assembleRelease --no-daemon
        if [ $? -ne 0 ]; then
            error "Build failed"
        fi
        local apk=$(find app/build/outputs/apk -name "*release*.apk" | head -1)
        [ -z "$apk" ] && error "APK not found"
        echo -e "${YELLOW}Warning: APK is unsigned. Sign it before installing.${RESET}"
        echo -e "  ${DIM}Output:${RESET} ${GREEN}$(realpath "$apk")${RESET}"
    else
        error "Invalid build type. Use 'debug' or 'release'"
    fi
}

build_flutter() {
    local build_type="$1"
    if [ "$build_type" = "release" ]; then
        error "Flutter release builds are not supported in Termux. Use 'apkgen build flutter' for debug build."
    fi
    step "Building Flutter debug APK (split ABI)..."
    flutter build apk --debug --split-per-abi
    if [ $? -eq 0 ]; then
        success "Build completed"
    else
        error "Build failed"
    fi
}

clean_project() {
    if [ -f "pubspec.yaml" ] || [ -d "lib" ] && [ -f "lib/main.dart" ]; then
        step "Cleaning Flutter project..."
        flutter clean
        if [ $? -eq 0 ]; then
            success "Flutter clean completed"
        else
            error "Flutter clean failed"
        fi
    elif [ -f "gradlew" ]; then
        ensure_gradlew
        step "Cleaning Android project..."
        rm -rf build
        ./gradlew clean --no-daemon
        if [ $? -eq 0 ]; then
            success "Android clean completed"
        else
            error "Clean failed"
        fi
    else
        error "Not in a recognized project (no pubspec.yaml/lib/main.dart or gradlew)"
    fi
}

# ------------------------------
# HELP
# ------------------------------
show_help() {
    show_banner
    echo -e "${WHITE}A CLI tool to quickly generate Android APKs from local templates.${RESET}\n"
    echo -e "${BOLD}USAGE:${RESET}"
    echo -e "  ${WHITE}apkgen${RESET} <command> [arguments]\n"
    echo -e "${BOLD}COMMANDS:${RESET}"
    echo -e "  ${CYAN}create${RESET} <dir> [--kotlin|--flutter|--nativecpp]"
    echo -e "        Create new app (Java default, or use a flag for Kotlin/Flutter/C++ native)"
    echo -e "  ${CYAN}build${RESET} debug"
    echo -e "        Build debug APK (Android)"
    echo -e "  ${CYAN}build${RESET} release"
    echo -e "        Build unsigned release APK (Android)"
    echo -e "  ${CYAN}build${RESET} flutter"
    echo -e "        Build debug APK (Flutter, split ABI)"
    echo -e "  ${CYAN}clean${RESET}"
    echo -e "        Clean build artifacts"
    echo -e "  ${CYAN}help${RESET}"
    echo -e "        Show this help message\n"
    echo -e "${BOLD}EXAMPLES:${RESET}"
    echo -e "  ${WHITE}apkgen create myapp${RESET}"
    echo -e "  ${WHITE}apkgen create myapp --kotlin${RESET}"
    echo -e "  ${WHITE}apkgen create myapp --flutter${RESET}"
    echo -e "  ${WHITE}apkgen create myapp --nativecpp${RESET}"
    echo -e "  ${WHITE}cd myapp && apkgen build debug${RESET}"
    echo -e "  ${WHITE}cd myflutter && apkgen build flutter${RESET}"
    echo -e "  ${WHITE}apkgen clean${RESET}\n"
}

# ------------------------------
# MAIN
# ------------------------------
case "$1" in
    create)
        shift
        create_app "$@"
        ;;
    build)
        if [ "$2" = "debug" ] || [ "$2" = "release" ]; then
            build_apk "$2"
        elif [ "$2" = "flutter" ]; then
            build_flutter "$3"
        else
            error "Usage: apkgen build {debug|release|flutter}"
        fi
        ;;
    clean) clean_project ;;
    help|--help|-h) show_help ;;
    *)
        if [ -z "$1" ]; then
            show_help
        else
            error "Unknown command '$1'. Run 'apkgen help' for usage."
        fi
        ;;
esac
